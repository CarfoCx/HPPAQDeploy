<UserControl x:Class="HPPAQDeploy.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:HPPAQDeploy.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <StackPanel>
                    <TextBlock Text="Deployment History" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="View and export past deployment records" Style="{StaticResource PageSubtitle}" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,16" Style="{StaticResource SectionTitle}"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="(" /><Run Text="{Binding FilteredHistory.Count, Mode=OneWay}" /><Run Text=")" />
                </TextBlock>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Export CSV" Command="{Binding ExportHistoryCsvCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        ToolTip="Export deployment history to CSV" />
                <Button Content="Clear History" Command="{Binding ClearHistoryCommand}"
                        Style="{StaticResource DangerButton}" Margin="0,0,8,0"
                        ToolTip="Delete all deployment history records" />
                <Button Content="Refresh" Command="{Binding LoadHistoryCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="Reload deployment history" />
            </StackPanel>
        </DockPanel>

        <!-- Filter -->
        <Border Grid.Row="1" Margin="0,0,0,12" Style="{StaticResource FilterBarBorder}">
            <DockPanel>
                <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalAlignment="Center" Margin="4,0,8,0" DockPanel.Dock="Left" />
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         materialDesign:HintAssist.Hint="Filter by hostname, IP, update name, SoftPaq ID, category, or action"
                         Style="{StaticResource FilterBarTextBox}" />
            </DockPanel>
        </Border>

        <!-- Empty State: No history at all -->
        <Border Grid.Row="2" Style="{StaticResource AppCard}">
            <Border.Visibility>
                <Binding Path="HasAnyHistory" Converter="{StaticResource InverseBoolToVis}" />
            </Border.Visibility>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                <materialDesign:PackIcon Kind="History" Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Text="No deployment history" Style="{StaticResource SectionTitle}"
                           HorizontalAlignment="Center" Margin="0,12,0,4" />
                <TextBlock Text="Deployment records will appear here after updates are installed."
                           Style="{StaticResource BodyText}" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Empty State: Filter returned no results -->
        <Border Grid.Row="2" Style="{StaticResource AppCard}"
                Visibility="{Binding IsFilterEmpty, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Text="No matching records" Style="{StaticResource SectionTitle}"
                           HorizontalAlignment="Center" Margin="0,12,0,4" />
                <TextBlock Text="No deployment records match the current filter."
                           Style="{StaticResource BodyText}" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- History DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource AppCard}"
                Visibility="{Binding HasHistory, Converter={StaticResource BoolToVis}}">
            <DataGrid ItemsSource="{Binding FilteredHistory}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Style="{StaticResource ProfessionalDataGrid}"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      CanUserResizeColumns="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp"
                                        Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                        Width="170" MinWidth="130" />
                    <DataGridTextColumn Header="Hostname" Binding="{Binding DeviceHostname}" Width="150" MinWidth="80" />
                    <DataGridTextColumn Header="IP Address" Binding="{Binding DeviceIpAddress}" Width="130" MinWidth="80" />
                    <DataGridTextColumn Header="Update" Binding="{Binding UpdateName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="ToolTip" Value="{Binding UpdateName}" /></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SoftPaq" Binding="{Binding SoftPaqId}" Width="90" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                    <DataGridTemplateColumn Header="Action" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Action}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Action}" Value="Deployed">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Action}" Value="Failed">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Action}" Value="Cancelled">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="ToolTip" Value="{Binding ErrorMessage}" /></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="4,8,0,0"
                   Style="{StaticResource SubtitleText}" Foreground="{StaticResource AccentGreenBrush}" />
    </Grid>
</UserControl>
