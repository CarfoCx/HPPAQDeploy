<UserControl x:Class="HPPAQDeploy.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:HPPAQDeploy.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Stretch" Margin="0,0,16,0">
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Configure application behavior and integrations" Style="{StaticResource PageSubtitle}" Margin="0,2,0,16" />

            <!-- Credentials (embedded from CredentialManagerView) -->
            <ContentControl Content="{Binding CredentialManager}" Margin="0,0,0,20" />

            <!-- Repository Sync -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="True" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="CloudSync" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Update Catalog" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Sync the HP update catalog to check devices for available driver and firmware updates."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,0,0,12" />
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Command="{Binding SyncRepositoryCommand}"
                                    IsEnabled="{Binding IsSyncingRepo, Converter={StaticResource InverseBool}}"
                                    Style="{StaticResource PrimaryButton}" Padding="16,6" Height="36"
                                    ToolTip="Download the latest HP update catalog for your scanned devices">
                                <StackPanel Orientation="Horizontal">
                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                 IsIndeterminate="True" Width="14" Height="14"
                                                 Foreground="{StaticResource HpBlueBrush}" Visibility="{Binding IsSyncingRepo, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,6,0" />
                                    <materialDesign:PackIcon Kind="CloudSync" Width="16" Height="16"
                                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Sync Catalog" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Text="{Binding RepoStatus}" Style="{StaticResource SubtitleText}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </DockPanel>
                        <TextBlock Text="{Binding RepoSyncStatus}" Margin="0,6,0,0"
                                   Style="{StaticResource SubtitleText}" Foreground="{StaticResource AccentOrangeBrush}"
                                   TextWrapping="Wrap" />

                        <DockPanel Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Use Offline Repository" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="Analyze and install from the synced repository instead of HP.com on each device"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" FontStyle="Italic" />
                            </StackPanel>
                            <CheckBox DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      IsChecked="{Binding UseOfflineRepository}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </DockPanel>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="Repository Share Path" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Optional UNC path reachable by target devices, for example \\server\share\Repository. Leave blank to copy the local repository to each target."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding RepositorySharePath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Performance Settings -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="Speedometer" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Performance" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,0,16">
                            <DockPanel>
                                <TextBlock Text="Ping Concurrency" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding PingConcurrency}"
                                           FontWeight="Bold" Foreground="{StaticResource HpBlueBrush}" />
                            </DockPanel>
                            <TextBlock Text="Number of simultaneous ping requests during network scan"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" FontStyle="Italic" />
                            <Slider Value="{Binding PingConcurrency}" Minimum="16" Maximum="1024"
                                    TickFrequency="16" IsSnapToTickEnabled="True"
                                    Foreground="{StaticResource HpBlueBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <DockPanel>
                                <TextBlock Text="WMI Discovery Concurrency" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding WmiConcurrency}"
                                           FontWeight="Bold" Foreground="{StaticResource HpBlueBrush}" />
                            </DockPanel>
                            <TextBlock Text="Number of simultaneous WMI queries for device discovery"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" FontStyle="Italic" />
                            <Slider Value="{Binding WmiConcurrency}" Minimum="1" Maximum="128"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Foreground="{StaticResource HpBlueBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <DockPanel>
                                <TextBlock Text="Deploy Concurrency" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding DeployConcurrency}"
                                           FontWeight="Bold" Foreground="{StaticResource HpBlueBrush}" />
                            </DockPanel>
                            <TextBlock Text="Number of simultaneous device deployments"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" FontStyle="Italic" />
                            <Slider Value="{Binding DeployConcurrency}" Minimum="1" Maximum="50"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Foreground="{StaticResource HpBlueBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Timeout Settings -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Timeouts" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Ping Timeout (ms)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="How long to wait for a ping response before marking device as offline"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding PingTimeoutMs}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Analysis Timeout (minutes)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Maximum time to wait for HPIA analysis to complete on a device"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding AnalysisTimeoutMinutes}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Deploy Timeout (minutes)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Maximum time to wait for update installation on a device"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding DeployTimeoutMinutes}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Scheduled Scans -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Scheduled Scans" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Enable Scheduled Scans" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <CheckBox DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      IsChecked="{Binding ScheduledScanEnabled}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </DockPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="CIDR Range" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Network range to scan on schedule (e.g. 10.0.0.0/24)"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding ScheduledScanCidr, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Scan Interval" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding IntervalOptions}"
                                      SelectedItem="{Binding SelectedInterval}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="{Binding LastScheduledScanText}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding NextScheduledScanText}" FontSize="12"
                                       Foreground="{StaticResource HpBlueBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Email Notifications -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="EmailOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Email Notifications" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Enable Email Notifications" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <CheckBox DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      IsChecked="{Binding EmailNotificationsEnabled}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </DockPanel>

                        <TextBlock Text="SMTP Server Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="SMTP Server" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SmtpServer, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SMTP Port" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding SmtpPort}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <DockPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                <TextBlock Text="Use SSL/TLS" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <CheckBox IsChecked="{Binding SmtpUseSsl}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                            </DockPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="SMTP Username" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Leave blank if your SMTP server does not require authentication"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding SmtpUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="SMTP Password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Encrypted with Windows DPAPI when saved"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <PasswordBox x:Name="SmtpPasswordBox"
                                         materialDesign:HintAssist.Hint="SMTP Password"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         PasswordChanged="SmtpPasswordBox_PasswordChanged"
                                         ToolTip="Encrypted with Windows DPAPI when saved" />
                        </StackPanel>

                        <TextBlock Text="Email Addresses" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,8" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="From Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding EmailFrom, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="To Address(es)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Comma-separated list of email addresses"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding EmailTo, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <TextBlock Text="Notification Types" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,8" />

                        <CheckBox Content="Notify on scan complete" IsChecked="{Binding NotifyOnScanComplete}"
                                  Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                        <CheckBox Content="Notify on critical updates found" IsChecked="{Binding NotifyOnCriticalUpdates}"
                                  Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                        <CheckBox Content="Notify on deployment complete" IsChecked="{Binding NotifyOnDeployComplete}"
                                  Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                        <CheckBox Content="Notify on deployment failure" IsChecked="{Binding NotifyOnDeployFailure}"
                                  Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Content="Send Test Email" Command="{Binding TestEmailCommand}"
                                    IsEnabled="{Binding IsTestingEmail, Converter={StaticResource InverseBool}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="24,6" Margin="0,0,8,0"
                                    ToolTip="Send a test email to verify your SMTP settings" />
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Width="14" Height="14"
                                         Foreground="{StaticResource HpBlueBrush}"
                                         Visibility="{Binding IsTestingEmail, Converter={StaticResource BoolToVis}}"
                                         Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TestEmailStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Paths -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="FolderCogOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="Paths" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="HPIA Executable Path" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding HpiaPath}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="{StaticResource TextPrimaryBrush}" IsReadOnly="True" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Repository Directory Path" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Local folder where downloaded SoftPaqs are stored during deployment"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" FontStyle="Italic" />
                            <TextBox Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- BIOS Passwords -->
            <Border Style="{StaticResource AppCard}" Margin="0,0,0,16">
                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <materialDesign:PackIcon Kind="LockOutline" Width="22" Height="22"
                                                     Foreground="{StaticResource HpBlueBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="BIOS Passwords" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="HPIA uses the first configured password when updating BIOS on password-protected devices."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,0,0,12" />

                        <!-- Add new password -->
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="Add"
                                    Command="{Binding AddBiosPasswordCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="16,6" Height="36" Margin="8,0,0,0" />
                            <TextBox Text="{Binding NewBiosPassword, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Enter BIOS password"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />
                        </DockPanel>

                        <!-- Password list -->
                        <ItemsControl ItemsSource="{Binding BiosPasswords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SubtleBackgroundBrush}"
                                            CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Command="{Binding DataContext.RemoveBiosPasswordCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove this BIOS password"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Height="24" Width="24" Padding="0"
                                                    VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentRedBrush}" />
                                            </Button>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Lock" Width="14" Height="14"
                                                                         Foreground="{StaticResource TextSecondaryBrush}"
                                                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding}" Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </Border>

            <!-- Save/Reset -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Save Settings" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="24,6" Margin="0,0,8,0"
                        ToolTip="Save all settings to disk" />
                <Button Content="Reset Defaults" Command="{Binding ResetCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="24,6"
                        ToolTip="Reset all settings to factory defaults" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
