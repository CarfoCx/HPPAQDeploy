<UserControl x:Class="HPPAQDeploy.App.Views.CredentialManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:HPPAQDeploy.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Slide-down animation for the form panel -->
        <Storyboard x:Key="SlideDownStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                             From="0" To="1" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.MaxHeight)"
                             From="0" To="300" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Status fade-out animation -->
        <Storyboard x:Key="StatusFadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.5"
                             BeginTime="0:0:3.5" />
        </Storyboard>

        <!-- Credential card ListBox item style -->
        <Style x:Key="CredentialCardItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent"
                                CornerRadius="6" Padding="12,10"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A0096D6" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource HpBlueBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#250096D6" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             HEADER
             ══════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="Credentials" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Manage credentials for remote device access (encrypted with DPAPI)"
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding NewCredentialCommand}"
                    Style="{StaticResource PrimaryButton}" Height="30" Padding="14,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Add Credential" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════
             ADD / EDIT FORM (slide-down collapsible)
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource AppCard}" Margin="0,0,0,8" Padding="0"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideDownStoryboard}" />
                </EventTrigger>
            </Border.Triggers>
            <StackPanel>
                <!-- Blue accent bar at top -->
                <Border Height="3" CornerRadius="6,6,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0096D6" Offset="0" />
                            <GradientStop Color="#00AAEE" Offset="0.5" />
                            <GradientStop Color="#0096D6" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Margin="14,12,14,12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="KeyPlus" Width="18" Height="18"
                                                 Foreground="{StaticResource HpBlueBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="New Credential" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Row 1: Label + Domain -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Label" Style="{StaticResource CaptionText}" />
                                <TextBlock Text=" *" Foreground="{StaticResource AccentRedBrush}" FontSize="11.5" />
                            </StackPanel>
                            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBox}"
                                     Height="32" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Domain" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBox}"
                                     Height="32" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Username + Password -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Username" Style="{StaticResource CaptionText}" />
                                <TextBlock Text=" *" Foreground="{StaticResource AccentRedBrush}" FontSize="11.5" />
                            </StackPanel>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBox}"
                                     Height="32" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Password" Style="{StaticResource CaptionText}" />
                                <TextBlock Text=" *" Foreground="{StaticResource AccentRedBrush}" FontSize="11.5" />
                            </StackPanel>
                            <PasswordBox x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         Height="32" FontSize="12"
                                         Foreground="White" Background="#12FFFFFF"
                                         BorderBrush="#33FFFFFF" BorderThickness="1"
                                         VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Actions row -->
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Left" Content="Set as default"
                                  IsChecked="{Binding IsDefault}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" Padding="14,4" Margin="0,0,6,0" />
                            <Button Command="{Binding SaveCredentialCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    Height="28" Padding="14,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Check" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Save" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             TOOLBAR BAR (credential count + Set as Default)
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="2,0,2,6"
                Visibility="{Binding HasCredentials, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ShieldKeyOutline" Width="15" Height="15"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center">
                        <Run Text="{Binding Credentials.Count, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{StaticResource HpBlueBrush}" />
                        <Run Text=" credential(s) stored" />
                    </TextBlock>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding SetAsDefaultCommand}"
                            Style="{StaticResource SmallButton}"
                            Height="26" Padding="10,3"
                            IsEnabled="{Binding CanSetAsDefault}"
                            ToolTip="Set the selected credential as the default for deployments">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="StarOutline" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="Set as Default" VerticalAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             MAIN CONTENT: Credential list + Test panel
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="380" />
            </Grid.ColumnDefinitions>

            <!-- ─── EMPTY STATE ─── -->
            <Border Grid.Column="0" Style="{StaticResource AppCard}"
                    Visibility="{Binding HasNoCredentials, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="#150096D6" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="KeyVariant" Width="32" Height="32"
                                                 Foreground="{StaticResource HpBlueBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="No credentials stored" Style="{StaticResource SectionTitle}"
                               HorizontalAlignment="Center" Margin="0,0,0,6" />
                    <TextBlock Text="Add a credential to connect to remote devices for deployment."
                               Style="{StaticResource BodyText}" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0"
                               Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Click " />
                        <Run Text="Add Credential" Foreground="{StaticResource HpBlueBrush}" FontWeight="SemiBold" />
                        <Run Text=" above to get started." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ─── CREDENTIAL CARD LIST ─── -->
            <Border Grid.Column="0" Style="{StaticResource AppCard}"
                    Visibility="{Binding HasCredentials, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Stored Credentials" Style="{StaticResource SectionTitle}"
                               Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Credentials}"
                             SelectedItem="{Binding SelectedCredential}"
                             ItemContainerStyle="{StaticResource CredentialCardItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Leading icon -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                            Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#150096D6" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                        <Setter Property="Background" Value="#2052C456" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <materialDesign:PackIcon Width="18" Height="18"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="KeyVariant" />
                                                    <Setter Property="Foreground" Value="{StaticResource HpBlueBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Kind" Value="ShieldCheck" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                    </Border>

                                    <!-- Label + Domain\Username -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0">
                                            <Run Text="{Binding Domain, Mode=OneWay}" />
                                            <Run Text="\" />
                                            <Run Text="{Binding Username, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Default badge -->
                                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                            Background="#28FFA020" Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Star" Width="12" Height="12"
                                                                     Foreground="{StaticResource AccentOrangeBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="Default" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentOrangeBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Encrypted badge -->
                                    <Border Grid.Column="3" CornerRadius="10" Padding="8,3"
                                            Background="#1552C456" Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Lock" Width="12" Height="12"
                                                                     Foreground="{StaticResource AccentGreenBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="Encrypted" FontSize="11"
                                                       Foreground="{StaticResource AccentGreenBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Created date -->
                                    <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionText}" Margin="0,0,12,0"
                                               Text="{Binding Created, StringFormat='{}{0:MMM dd, yyyy}'}" />

                                    <!-- Delete button -->
                                    <Button Grid.Column="5"
                                            Command="{Binding DataContext.DeleteCredentialCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            Width="30" Height="30" Padding="0" MinWidth="0"
                                            ToolTip="Delete" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                                        Width="30" Height="30">
                                                    <materialDesign:PackIcon Kind="TrashCanOutline" Width="15" Height="15"
                                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                             Foreground="{StaticResource AccentRedBrush}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#33F44336" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ─── TEST CONNECTION PANEL ─── -->
            <Border Grid.Column="2" Style="{StaticResource AppCard}">
                <StackPanel>
                    <!-- Panel header with icon -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="LanConnect" Width="18" Height="18"
                                                 Foreground="{StaticResource HpBlueBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Test Connection" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Selected credential display -->
                    <Border Background="{StaticResource SubtleBackgroundBrush}" CornerRadius="6"
                            Padding="10,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="AccountKeyOutline" />
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedCredential}" Value="True">
                                                <Setter Property="Kind" Value="AccountKey" />
                                                <Setter Property="Foreground" Value="{StaticResource HpBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Text="{Binding SelectedCredentialLabel}" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedCredential}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8">
                        Select a credential, enter a target hostname or IP, and click Test to verify WMI and SMB access.
                    </TextBlock>

                    <TextBlock Text="Target Host" Style="{StaticResource CaptionText}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding TestHostInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBox}"
                             Height="32" FontSize="12"
                             Margin="0,0,0,10" />

                    <Button Padding="14,4" Height="30"
                            Command="{Binding TestCredentialCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Play" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Test Connection" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Loading spinner -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0"
                                Visibility="{Binding IsTestingCredential, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Width="18" Height="18"
                                     Foreground="{StaticResource HpBlueBrush}" />
                        <TextBlock Text="Testing..." Style="{StaticResource CaptionText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Results: WMI + SMB badges -->
                    <Border Margin="0,10,0,0"
                            Visibility="{Binding IsTestingCredential, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel>
                            <!-- Only show results when we actually have them -->
                            <Grid Margin="0,0,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WmiResult}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WmiResult}" Value="OK">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WmiResult}" Value="Failed">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WmiResult}" Value="Testing">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WmiResult}" Value="Error">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- WMI Result Badge -->
                                <Border Grid.Row="0" CornerRadius="6" Padding="10,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SubtleBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WmiResult}" Value="OK">
                                                    <Setter Property="Background" Value="#1552C456" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding WmiResult}" Value="Failed">
                                                    <Setter Property="Background" Value="#15F4524A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <materialDesign:PackIcon DockPanel.Dock="Left" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="HelpCircleOutline" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WmiResult}" Value="OK">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WmiResult}" Value="Failed">
                                                            <Setter Property="Kind" Value="CloseCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="WMI" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding WmiResult}" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WmiResult}" Value="OK">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WmiResult}" Value="Failed">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- SMB Result Badge -->
                                <Border Grid.Row="2" CornerRadius="6" Padding="10,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SubtleBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SmbResult}" Value="OK">
                                                    <Setter Property="Background" Value="#1552C456" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SmbResult}" Value="Failed">
                                                    <Setter Property="Background" Value="#15F4524A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <materialDesign:PackIcon DockPanel.Dock="Left" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="HelpCircleOutline" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SmbResult}" Value="OK">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SmbResult}" Value="Failed">
                                                            <Setter Property="Kind" Value="CloseCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="SMB" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding SmbResult}" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SmbResult}" Value="OK">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SmbResult}" Value="Failed">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <!-- Fallback text result for error messages with detail -->
                            <TextBlock Text="{Binding TestResult}" Style="{StaticResource CaptionText}"
                                       TextWrapping="Wrap" Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             STATUS BAR (auto-fading)
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Margin="4,8,0,0"
                Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="InformationOutline" Width="14" Height="14"
                                         Foreground="{StaticResource AccentGreenBrush}"
                                         VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource CaptionText}"
                           Foreground="{StaticResource AccentGreenBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
