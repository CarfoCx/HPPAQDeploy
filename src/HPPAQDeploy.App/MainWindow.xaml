<Window x:Class="HPPAQDeploy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HPPAQDeploy.App.ViewModels"
        xmlns:views="clr-namespace:HPPAQDeploy.App.Views"
        Title="{Binding CurrentViewName, StringFormat='HPPAQDeploy — {0}'}"
        Width="1400" Height="850"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        x:Name="MainAppWindow"
        Background="{StaticResource ContentBgBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding NavigateToCommand}" CommandParameter="{Binding CurrentViewName}" />
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Dashboard" />
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Devices" />
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Groups" />
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Deploy" />
        <KeyBinding Key="D5" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="History" />
        <KeyBinding Key="D6" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Logs" />
        <KeyBinding Key="D7" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Settings" />
        <KeyBinding Key="D8" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Credentials" />
        <KeyBinding Key="F1" Command="{Binding ShowKeyboardShortcutsCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!-- View-ViewModel DataTemplate mappings -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DevicesViewModel}">
            <views:DevicesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupsViewModel}">
            <views:GroupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeployViewModel}">
            <views:DeployView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CredentialManagerViewModel}">
            <views:CredentialManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}">
            <views:LogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{StaticResource TopNavBarBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" Direction="270" BlurRadius="6" Opacity="0.25" Color="Black" />
            </Border.Effect>
            <DockPanel>
                <!-- App Branding (Left) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,24,0">
                    <materialDesign:PackIcon Kind="MonitorDashboard" Width="22" Height="22"
                                             Foreground="{StaticResource HpBlueBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="HPPAQDeploy" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource HpBlueBrush}"
                               VerticalAlignment="Center" />
                    <!-- Subtle separator -->
                    <Border Width="1" Height="20" Background="{StaticResource DividerBrush}"
                            VerticalAlignment="Center" Margin="16,0,0,0" />
                </StackPanel>

                <!-- Utility Tabs (Right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Border Width="1" Height="20" Background="{StaticResource DividerBrush}"
                            VerticalAlignment="Center" Margin="0,0,2,0" />

                    <RadioButton GroupName="Nav" Tag="Credentials"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Credentials"
                                 ToolTip="Manage stored credentials (Ctrl+8)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="KeyVariant" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Credentials" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="Logs"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Logs"
                                 ToolTip="View application logs (Ctrl+6)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Text" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Logs" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="Settings"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Settings"
                                 ToolTip="Configure application settings (Ctrl+7)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="About"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="About"
                                 ToolTip="About HPPAQDeploy">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="About" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <Button Command="{Binding OpenSupportLinkCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            ToolTip="Support HPPAQDeploy" Margin="0,0,8,0" Padding="12,0" Height="30"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Heart" Width="16" Height="16"
                                                     Foreground="{StaticResource AccentRedBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Support" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Primary Tabs (Center) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"
                            HorizontalAlignment="Left">
                    <RadioButton GroupName="Nav" IsChecked="True" Tag="Dashboard"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                                 ToolTip="Overview of all devices and update status (Ctrl+1)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="Devices"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Devices"
                                 ToolTip="View devices, scan network, add devices (Ctrl+2)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Monitor" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Devices" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="Groups"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Groups"
                                 ToolTip="Organize devices into groups (Ctrl+3)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Groups" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="Deploy"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Deploy"
                                 ToolTip="Deploy selected updates to devices (Ctrl+4)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="RocketLaunch" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Deploy Updates" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Tag="History"
                                 Style="{StaticResource TopTabRadioButton}"
                                 Command="{Binding NavigateToCommand}" CommandParameter="History"
                                 ToolTip="View deployment history (Ctrl+5)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="History" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <Border Padding="24,16">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>

            <!-- Snackbar Toast Notification -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,16" CornerRadius="6" Padding="20,10"
                    Background="#E0282840"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Visibility="{Binding IsSnackbarVisible, Converter={StaticResource BoolToVis}}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.4" Color="Black" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="18" Height="18"
                                             Foreground="{StaticResource AccentGreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding SnackbarMessage}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBgBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status indicator dot -->
                    <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource InactiveDotBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOnlineDevices}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="Devices: " />
                        <Run Text="{Binding DeviceCount}" Foreground="{StaticResource HpBlueBrush}" FontWeight="SemiBold" />
                    </TextBlock>
                    <Border Width="1" Height="12" Background="{StaticResource ProgressBarTrackBrush}"
                            Margin="0,0,16,0" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="Online: " />
                        <Run Text="{Binding OnlineCount}" Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold" />
                    </TextBlock>
                    <Border Width="1" Height="12" Background="{StaticResource ProgressBarTrackBrush}"
                            Margin="0,0,16,0" VerticalAlignment="Center" />
                    <TextBlock Text="v1.0.0 | HPIA 5.3.4" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.6"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
